@model Rad.Model.Accomodation

<div class="container mt-4">
    <div class="row">
        <div class="col-md-7">
            <h2>@Model.Name</h2>
            <p><strong>Grad:</strong> @Model.City?.Name</p>
            <p><strong>Kapacitet:</strong> @Model.Capacity</p>
            <p><strong>Površina:</strong> @Model.Size m²</p>

            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="Slika smještaja" class="img-fluid rounded shadow-sm mb-3" />
            }

            <p>Ovaj smještaj nalazi se u @Model.City?.Name i savršen je izbor za odmor nakon napornog tjedna. 
                @Model.Name može primiti maksimalno @Model.Capacity gostiju u svojih @Model.Size kvadratnih metara.<a href="#"></a>
                Posjetite @Model.Name kako bi iskusili idilu prirode i mira.
            </p>

            <a asp-action="Create" asp-controller="Reservation" asp-route-accomodationId="@Model.ID" class="btn btn-primary mt-2">
                Rezerviraj
            </a>
        </div>

        <div class="col-md-5">
            <h4 class="mb-3">Recenzije</h4>
            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                <div class="list-group">
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="list-group-item mb-2 border rounded shadow-sm">
                            <h5 class="mb-1">@review.Title</h5>
                            <p class="mb-0">@review.Content</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">Nema recenzija.</p>
            }
        </div>
    </div>
</div>
